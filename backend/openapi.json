{
  "openapi": "3.1.0",
  "info": {
    "title": "Job Agent API",
    "description": "Backend for an automated job-discovery assistant. Ingests listings from Adzuna, Jooble, and Apify (Indeed/LinkedIn), embeds them with `text-embedding-3-small`, and matches them against uploaded CVs via pgvector similarity search + GPT-4o-mini reranking. Users supply the CV and a prompt; the API returns ranked apply-links.",
    "version": "0.1.0"
  },

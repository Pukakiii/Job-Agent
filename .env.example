POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=job_agent
POSTGRES_PORT=5433
# POSTGRES_HOST defaults to "localhost"; set to "postgres" when the app runs inside Compose.
# DATABASE_URL is assembled from the POSTGRES_* values above (see app/core/config.py) — do not set it here.

SECRET_KEY=change-me
ENVIRONMENT=development

REDIS_URL=redis://localhost:6379

LOG_LEVEL=INFO

# AI — local
OLLAMA_BASE_URL=http://localhost:11434

# AI — API / BYOK (optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Scraping
APIFY_API_TOKEN=

# CV storage (S3 / MinIO)
# Local dev uses MinIO; the S3 client authenticates with the MINIO_ROOT_* creds.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123   # must be >= 8 chars
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
# S3_ENDPOINT_URL: http://localhost:9000 (local) or http://minio:9000 (in Compose);
# leave unset to target real AWS S3.
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET_NAME=cvs
S3_REGION=us-east-1
# Encrypt CVs at rest. Leave unset for local MinIO (no KMS); set S3_SSE=AES256 on real AWS S3.
# S3_SSE=AES256
# Used only when targeting real AWS S3 (S3_ENDPOINT_URL unset):
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Email — choose Postmark or Gmail
POSTMARK_API_TOKEN=
POSTMARK_SENDER_EMAIL=

GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=

FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Frontend — copy frontend/.env.example to frontend/.env.local
# NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_ENABLE_MSW=false   # set true to use MSW mocks instead of live API

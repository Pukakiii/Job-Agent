#!/usr/bin/env bash
# Pre-commit hook: sync AI rules source into .github/instructions/global-rules.instructions.md
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
SRC="$REPO_ROOT/ai-agents/global-rules.md"
DST="$REPO_ROOT/.github/instructions/global-rules.instructions.md"

if [ ! -f "$SRC" ]; then
  echo "Source AI rules file not found: $SRC" >&2
  exit 1
fi

# Read full source and strip leading frontmatter block (the first --- ... --- block)
AWK_SCRIPT='BEGIN{inblock=0; printed=0}
{ if (NR==1 && $0=="---") { inblock=1; next } 
  if (inblock==1 && $0=="---") { inblock=0; next }
  if (inblock==1) next
  print
}'

BODY=$(awk "$AWK_SCRIPT" "$SRC")

cat > "$DST" <<EOF
---
applyTo: "**"
---

$BODY
EOF

echo "AI rules synced"

exit 0

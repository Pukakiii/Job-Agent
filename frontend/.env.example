# Backend target for Next.js /api/v1 rewrites in dev (see next.config.ts).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Default API mode when no browser override is set (Settings → Developer).
# true  = MSW mock API (login works without backend)
# false = live backend via dev proxy (requires docker compose)
NEXT_PUBLIC_ENABLE_MSW=true

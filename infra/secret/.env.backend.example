POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=job_agent
POSTGRES_PORT=5433
# POSTGRES_HOST defaults to "localhost"; set to "postgres" when the app runs inside Compose.
# DATABASE_URL is assembled from the POSTGRES_* values above (see app/core/config.py) — do not set it here.

SECRET_KEY=change-me
ENVIRONMENT=development

REDIS_URL=redis://localhost:6379

LOG_LEVEL=INFO

# AI — local
OLLAMA_BASE_URL=http://localhost:11434

# AI — API / BYOK (optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Job ingestion / sources ────────────────────────────────────────────────
# Embedding dimension — must match the jobs.embedding Vector(768) column. Leave at 768.
EMBED_DIM=768
# Per-source HTTP timeout (seconds) and the queries the nightly cron ingests.
SOURCE_HTTP_TIMEOUT=30.0
# List value is JSON-encoded; uncomment to override the default ["python developer"].
# INGEST_DEFAULT_QUERIES=["python developer","data engineer"]

# Adzuna (sanctioned API). Disabled effectively unless APP_ID + APP_KEY are set.
ADZUNA_ENABLED=true
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=gb

# Jooble (sanctioned API). Disabled effectively unless API_KEY is set.
JOOBLE_ENABLED=true
JOOBLE_API_KEY=

# Indeed via Apify (scraped — best-effort, off by default). Needs APIFY_API_TOKEN.
INDEED_ENABLED=false
APIFY_API_TOKEN=

# CV storage (S3 / MinIO)
# Local dev uses MinIO; the S3 client authenticates with the MINIO_ROOT_* creds.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123   # must be >= 8 chars
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
# S3_ENDPOINT_URL: http://localhost:9000 (local) or http://minio:9000 (in Compose);
# leave unset to target real AWS S3.
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET_NAME=cvs
S3_REGION=us-east-1
# Encrypt CVs at rest. Leave unset for local MinIO (no KMS); set S3_SSE=AES256 on real AWS S3.
# S3_SSE=AES256
# Used only when targeting real AWS S3 (S3_ENDPOINT_URL unset):
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Email — choose Postmark or Gmail
POSTMARK_API_TOKEN=
POSTMARK_SENDER_EMAIL=

GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=

FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
